@model List<Blindsync_PAS_System.Models.ResearchArea>

@{
    ViewData["Title"] = "Research Areas";
}

@section Styles {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/Admin/ResearchAreaStyle.css" asp-append-version="true" />
}

@if (TempData["SuccessMessage"] != null)
{
    <div id="toastNotification" class="custom-toast">
        <i class="fas fa-check-circle"></i>
        <span>@TempData["SuccessMessage"]</span>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div id="toastNotificationError" class="custom-toast error-toast">
        <i class="fas fa-exclamation-circle"></i>
        <span>@TempData["ErrorMessage"]</span>
    </div>
}

<div class="admin-container">
    <h1 class="welcome-text">Welcome, Admin!</h1>

    <div class="input-group-container">
        <input type="text" id="newAreaInput" class="custom-input" placeholder="Enter new research area..." />
        <button class="btn-add" onclick="addNewArea()">
            <i class="fas fa-plus"></i> Add Research Area
        </button>
    </div>

    <div class="tags-container">
        <h2>Active Research Areas</h2>
        <div class="areas-grid" id="areasContainer">
            @if (Model != null)
            {
                foreach (var area in Model)
                {
                    <div class="area-tag" id="area-@area.Id">
                        <span>@area.Name</span>
                        <i class="fas fa-times btn-delete-tag" onclick="deleteArea(@area.Id)"></i>
                    </div>
                }
            }
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/Admin/ResearchArea.js" asp-append-version="true"></script>
}