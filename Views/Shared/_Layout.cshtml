<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BlindSync</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Blindsync_PAS_System.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        
        @if (User.IsInRole("Admin"))
        {
            @await Html.PartialAsync("_AdminNavbar")
        }
        else if (User.IsInRole("Supervisor"))
        {
            @await Html.PartialAsync("_SupervisorNavbar")
        }
        else
        {
            @await Html.PartialAsync("_StudentNavbar")
        }
    </header>

    <div class="container">
        <main role="main" class="pb-3 mt-4">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-5">
        <div class="container text-center">
            &copy; 2026 - BlindSync PAS System
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>