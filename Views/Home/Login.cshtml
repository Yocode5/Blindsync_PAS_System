@model Blindsync_PAS_System.ViewModels.LoginVM

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - BlindSync</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="icon" type="image/x-icon" href="~/favicon2.png" />
    <link href="https://fonts.googleapis.com/css2?family=Sansation:ital,wght@0,300;0,400;0,700;1,300;1,400;1,700&display=swap" rel="stylesheet">

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="stylesheet" href="~/css/Home/LoginStyle.css" asp-append-version="true" />
</head>
<body>

    <div class="main-wrapper">
        <div class="brand-section">
            <h1>BlindSync</h1>
            <p>Project Approval System</p>
        </div>

        <div class="login-card">
            <h2>Login</h2>

            <form asp-controller="Home" asp-action="Login" method="post">
                @Html.AntiForgeryToken()

                @if (ViewData.ModelState.Any(m => m.Value.Errors.Any()))
                {
                    <div id="loginErrorTrigger" data-error="Invalid email or password!"></div>
                }

                <div asp-validation-summary="ModelOnly" id="server-errors" style="display: none;"></div>

                <div style="margin-bottom: 20px;">
                    <label asp-for="Email" class="form-label">Email</label>
                    <input asp-for="Email" class="custom-input" placeholder="Enter Your Email..." />
                    <span asp-validation-for="Email" class="text-danger small" style="display:block; margin-top:5px;"></span>
                </div>

                <div style="margin-bottom: 20px;">
                    <label asp-for="Password" class="form-label">Password</label>
                    <div class="input-icon-wrapper">
                        <input asp-for="Password" type="password" id="passwordInput" class="custom-input" placeholder="Enter Password..." />
                        <i class="bi bi-eye" id="togglePassword"></i>
                    </div>
                    <span asp-validation-for="Password" class="text-danger small" style="display:block; margin-top:5px;"></span>
                </div>

                <button type="submit" class="btn-login">Login</button>
            </form>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script src="~/js/Home/Login.js"></script>

</body>
</html>