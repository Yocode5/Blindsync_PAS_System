@model Blindsync_PAS_System.ViewModels.AdminOverviewVM

@{
    ViewData["Title"] = "Admin Dashboard";
   
}
@section Styles {
    <link rel="stylesheet" href="~/css/Admin/OverviewStyle.css" />
}

    <div class="admin-container">        
        <h1 class="welcome-text">Welcome, Admin!</h1>
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-title"> Students</div>
                <div class="stat-value">@Model.TotalStudents</div>
            </div>
            <div class="stat-card">
                <div class="stat-title"> Total Matched</div>
                <div class="stat-value">@Model.TotalMatched</div>
            </div>
            <div class="stat-card">
                <div class="stat-title">👨‍🏫 Supervisors</div>
                <div class="stat-value">@Model.TotalSupervisors</div>
            </div>
            <div class="stat-card">
                <div class="stat-title">⏳ Pending</div>
                <div class="stat-value">@Model.TotalPending</div>
            </div>
        </div>
        <div class="table-container">
            <h2>System Overview</h2>
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Project Title</th>
                        <th>Student ID</th>
                        <th>Student Name</th>
                        <th>Supervisor Name</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if(Model.Projects != null && Model.Projects.Any())
                    {
                        foreach(var project in Model.Projects)
                        {
                            <tr>
                                <td>@project.ProjectTitle</td>
                                <td>@project.StudentId</td>
                                <td>@project.StudentName</td>
                                <td>@project.SupervisorName</td>
                                <td>
                                    <span class="status-badge status-@project.Status.Replace(" ", "-")">
                                        @project.Status
                                    </span>
                                </td>
                                <td>
                            <div class="action-icons">
                                <span title="Delete" style="cursor: pointer;">
                                    <i class="fas fa-times" style="color: #ef4444; font-size: 1.2rem; margin-right: 10px;"></i>
                                </span>
                                
                                <span title="Reassign Supervisor" onclick="openReassignModal(@project.ProjectId, '@project.StudentName', '@project.ProjectTitle', '@project.SupervisorName')" style="cursor: pointer;">
                                    <i class="fas fa-sync-alt" style="color: #10b981; font-size: 1.2rem;"></i>
                                </span>
                            </div>
                        </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
    <div id="reassignModal" class="modal-overlay" style="display: none;">
    <div class="modal-content">
        <div class="modal-header">
            <h2>Reassign Supervisor</h2>
            <i class="fas fa-times close-modal" onclick="closeReassignModal()"></i>
        </div>
        <div class="modal-body">
            <p><strong>Student Name:</strong> <span id="modalStudentName"></span></p>
            <p><strong>Project Name:</strong> <span id="modalProjectName"></span></p>
            <p><strong>Current Supervisor:</strong> <span id="modalCurrentSupervisor"></span></p>
            
            <div style="margin-top: 1.5rem;">
                <label style="font-weight: bold; font-size: 1.1rem;">Select Supervisor:</label>
                <select class="custom-select" id="newSupervisorSelect">
                    <option value="">[Select New Supervisor]</option>
                    
                    @if (ViewBag.Supervisors != null)
                    {
                        foreach (var supervisor in ViewBag.Supervisors)
                        {
                            <option value="@supervisor.Id">@supervisor.FullName</option>
                        }
                    }
                </select>
            </div>
            </div>
        <div class="modal-footer">
            <button class="btn-reassign" onclick="submitReassign()">Reassign</button>
            <button class="btn-cancel" onclick="closeReassignModal()">Cancel</button>
        </div>
    </div>
</div>
<script src="~/js/Admin/Overview.js" asp-append-version="true"></script>
