@model Blindsync_PAS_System.Models.Student

@{
    ViewData["Title"] = "Student Dashboard";
}

@if (TempData["SuccessMessage"] != null)
{
    <div id="toastNotification" class="custom-toast">
        <i class="fas fa-check-circle"></i>
        <span>@TempData["SuccessMessage"]</span>
    </div>
}

<div class="dashboard-page">
    <div class="dashboard-content">
        <h1 class="welcome-text">Welcome, @Model.UserAccount.FirstName</h1>

        <div class="status-card">
            @if (ViewBag.ActiveProject != null)
            {
                var project = ViewBag.ActiveProject as Project;

                <div class="matching-header">
                    <h3 class="card-title" style="margin-bottom: 0;">Matching Status</h3>

                    @switch (project.Status)
                    {
                        case Blindsync_PAS_System.Models.ProjectStatus.Matched:
                            <span class="status-badge accepted" style="background-color: #2e9f6b;">Matched</span>
                            break;

                        case Blindsync_PAS_System.Models.ProjectStatus.UnderReview:
                            <span class="status-badge review" style="background-color: #3498db; color: white;">Under Review</span>
                            break;

                        case Blindsync_PAS_System.Models.ProjectStatus.Pending:
                        default:
                            <span class="status-badge pending">Pending</span>
                            break;
                    }
                </div>

                <div class="matching-body">

                    <div class="proposal-details-box">
                        <div class="proposal-title-row">
                            <i class="fas fa-file-alt proposal-icon"></i>
                            <h4>@project.Title</h4>
                        </div>

                        <p class="detail-row"><strong>Research Area:</strong> @project.Area.Name</p>

                        <div class="detail-row tech-stack-display">
                            <strong>Tech Stack:</strong>
                            <div class="readonly-tags">
                                @if (!string.IsNullOrEmpty(project.TechStack))
                                {
                                    @foreach (var tech in project.TechStack.Split(new[] { ',' }, StringSplitOptions.RemoveEmptyEntries))
                                    {
                                        <span class="tech-tag readonly">@tech</span>
                                    }
                                }
                            </div>
                        </div>

                        <a href="#" class="view-details-link">View More Details</a>

                        <div class="proposal-actions">
                            <button class="btn-action edit" onclick="openEditModal('@project.Title', '@project.ResearchAreaId', '@project.TechStack', '@project.Abstract')">Edit Submission</button>

                            <form id="withdrawForm" asp-action="WithdrawProposal" method="post" style="flex: 1; display: flex;">
                                <input type="hidden" name="projectId" value="@project.Id" />
                                <button type="button" class="btn-action withdraw" onclick="confirmWithdrawal()">
                                    Withdraw
                                </button>
                            </form>
                        </div>
                    </div>

                    <div class="matching-divider"></div>

                    @if (project.SupervisorId == null)
                    {
                        <div class="supervisor-status-box dashed">
                            <p>No Supervisor<br>Assigned yet</p>
                        </div>
                    }
                    else
                    {
                        <div class="supervisor-status-box filled">
                            <div class="supervisor-title-row">
                                <i class="fas fa-user-friends supervisor-icon"></i>
                                <h4>@project.AssignedSupervisor.UserAccount.FirstName @project.AssignedSupervisor.UserAccount.LastName</h4>
                            </div>

                            <p class="detail-row">
                                <strong>Supervisor Email:</strong>
                                <span style="margin-left: 8px;">@project.AssignedSupervisor.UserAccount.Email</span>
                            </p>

                            <div class="detail-row assign-date-display">
                                <strong>Date of Assigning:</strong>
                                <div class="readonly-tags" style="margin-top: 8px;">
                                    <span class="tech-tag readonly" style="background-color: #123145;">
                                        @(project.AssignedAt?.ToString("dd/MM/yyyy") ?? "N/A")
                                    </span>
                                </div>
                            </div>

                            <a href="mailto:@project.AssignedSupervisor.UserAccount.Email?subject=Regarding Project Proposal: @project.Title"
                               class="btn-collaborate"
                               style="text-decoration: none; width: fit-content;">
                                <i class="fas fa-comment-dots"></i> Collaborate
                            </a>
                        </div>
                    }
                </div>
            }
            else
            {
                <h3 class="card-title">Matching Status</h3>
                <div class="add-project-zone" onclick="openModal()">
                    <div class="icon-circle">
                        <i class="fas fa-plus"></i>
                    </div>
                    <p>Create a Proposal</p>
                </div>
            }
        </div>
    </div>
</div>

<div id="proposalModal" class="modal-overlay">
    <div class="modal-container">
        <div class="modal-header">
            <h2>Create Proposal</h2>
            <span class="close-btn" onclick="closeModal()">&times;</span>
        </div>

        <form asp-controller="Students" asp-action="CreateProposal" method="post" class="modal-form">
            <div class="form-row">
                <div class="form-group">
                    <label>Project Title</label>
                    <input type="text" name="Title" placeholder="Enter title..." class="soft-input" required>
                </div>
                <div class="form-group">
                    <label>Research Area</label>

                    <div class="custom-dropdown-container" id="researchDropdown">
                        <div class="custom-dropdown-trigger" onclick="toggleDropdown(event)">
                            <span id="selectedResearchText">Select Research Area</span>
                            <i class="fas fa-chevron-down dropdown-icon"></i>
                        </div>

                        <input type="hidden" name="ResearchAreaId" id="hiddenResearchAreaId" required>

                        <ul class="custom-dropdown-options" id="dropdownOptions">
                            @if (ViewBag.ResearchAreas != null)
                            {
                                foreach (var area in ViewBag.ResearchAreas)
                                {
                                    <li onclick="selectResearchArea('@area.Id', '@area.Name')">@area.Name</li>
                                }
                            }
                        </ul>
                    </div>
                </div>
            </div>

            <div class="form-group">
                <label>Tech Stack</label>
                <input type="text" id="techInput" placeholder="e.g. React, Node.js (Press Enter)" class="soft-input">
                <input type="hidden" name="TechStack" id="hiddenTechStack">
                <div class="tag-container" id="techTagContainer"></div>
            </div>

            <div class="form-group">
                <label>Abstract</label>
                <textarea name="Abstract" rows="5" class="soft-input" placeholder="Enter abstract..." required></textarea>
            </div>

            <div class="modal-actions">
                <button type="submit" class="btn-add">Add</button>
                <button type="button" class="btn-cancel" onclick="closeModal()">Cancel</button>
            </div>
        </form>
    </div>
</div>

<div id="editProposalModal" class="modal-overlay" onclick="closeEditModalOutside(event)" style="display: none;">
    <div class="modal-container">
        <div class="modal-header">
            <h2>Edit Proposal</h2>
            <span class="close-btn" onclick="closeEditModal()">&times;</span>
        </div>

        <div class="modal-body">
            <div class="form-row"> 
                <div class="form-group">
                    <label>Project Title</label>
                    <input type="text" id="editFieldProjectTitle" class="soft-input" placeholder="[Pre Filled]">
                </div>
                
                <div class="form-group">
                    <label>Research Area</label>
                    <div class="custom-dropdown-container" id="editResearchDropdown">
                        <div class="custom-dropdown-trigger" onclick="toggleEditDropdown(event)">
                            <span id="editSelectedResearchText">Select Research Area</span>
                            <i class="fas fa-chevron-down dropdown-icon" id="editDropdownIcon"></i>
                        </div>

                        <input type="hidden" name="ResearchAreaId" id="hiddenEditResearchAreaId">

                        <ul class="custom-dropdown-options" id="editDropdownOptions">
                            <li onclick="selectEditResearchArea('1', 'Artificial Intelligence')">Artificial Intelligence</li>
                            <li onclick="selectEditResearchArea('2', 'Software Engineering')">Software Engineering</li>
                            <li onclick="selectEditResearchArea('3', 'Data Science')">Data Science</li>
                            <li onclick="selectEditResearchArea('4', 'Cyber Security')">Cyber Security</li>
                        </ul>
                    </div>
                </div>
            </div>

            <div class="form-group">
                <label>Tech Stack</label>
                <input type="text" id="editFieldTechStack" class="soft-input" placeholder="Tech Stack">
                <div class="tag-container" id="editTagContainerElement">
                     <span class="tech-tag">React <i onclick="this.parentElement.remove()">&times;</i></span>
                </div>
            </div>

            <div class="form-group">
                <label>Abstract</label>
                <textarea id="editFieldAbstract" class="soft-input" rows="5" placeholder="[Pre Filled]"></textarea>
            </div>
        </div>

        <div class="modal-actions">
            <button type="button" class="btn-add" onclick="submitEdit()">Edit</button>
            <button type="button" class="btn-cancel" onclick="closeEditModal()">Cancel</button>
        </div>
    </div>
</div>