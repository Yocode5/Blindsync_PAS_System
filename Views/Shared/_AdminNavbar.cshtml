@{
    var currentAction = ViewContext.RouteData.Values["Action"]?.ToString();
}

<nav class="custom-navbar">
    <div class="nav-brand">
        <strong>BlindSync</strong>
    </div>

    <div class="nav-links">
        <a asp-controller="Admin" asp-action="Overview" class="nav-item @(currentAction == "Overview" ? "active" : "")">
            <i class="fas fa-th-large"></i> Overview
        </a>

        <a asp-controller="Admin" asp-action="Users" class="nav-item @(currentAction == "Users" ? "active" : "")">
            <i class="fas fa-user"></i> Users
        </a>

        <a asp-controller="Admin" asp-action="ResearchAreas" class="nav-item @(currentAction == "ResearchAreas" ? "active" : "")">
            <i class="fas fa-book-open"></i> Research Areas
        </a>
    </div>

    <div class="nav-actions">
        <a href="javascript:void(0)" onclick="openProfileModal()" class="btn btn-profile" style="text-decoration: none;">
            <i class="fas fa-user-circle"></i> Profile
        </a>

        <form asp-controller="Home" asp-action="Logout" method="post" style="margin: 0;">
            <button type="submit" class="btn btn-logout">
                <i class="fas fa-sign-out-alt"></i> Logout
            </button>
        </form>
    </div>
</nav>