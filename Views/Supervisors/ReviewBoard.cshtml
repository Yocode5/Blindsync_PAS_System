@model Blindsync_PAS_System.ViewModels.SupervisorDashboardViewModel

@{
    ViewData["Title"] = "Review Board";
}

@section Styles {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/Supervisor/ReviewBoardStyle.css" asp-append-version="true" />
}

@if (TempData["SuccessMessage"] != null)
{
    <div id="toastNotification" class="custom-toast">
        <i class="fas fa-check-circle"></i>
        <span>@TempData["SuccessMessage"]</span>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div id="toastNotificationError" class="custom-toast error-toast">
        <i class="fas fa-exclamation-circle"></i>
        <span>@TempData["ErrorMessage"]</span>
    </div>
}

<div class="container mt-4 dashboard-wrapper">
    <h3>Welcome, @Model.FirstName</h3>

    <div class="main-content-box">
        <div class="filter-section">
            <h4>Filter My Expertise</h4>

            <div class="search-container">
                <input type="text" id="projectSearch" class="search-input" placeholder="Search by project name or research area..." autocomplete="off">
                <div id="autocompleteList" class="autocomplete-items"></div>
            </div>

            <div id="selectedTags" class="selected-tags-container">
            </div>

            <h5 class="available-categories-title">Available categories to select:</h5>
            <div id="availableTags" class="available-categories-container">
                @foreach (var area in Model.AvailableResearchAreas)
                {
                    <span class="available-tag" data-name="@area">@area</span>
                }
            </div>
        </div>

        <hr style="border-color: rgba(255,255,255,0.1); margin: 25px 0;">

        <h4 class="aligned-projects-header">Aligned Projects</h4>
        <p id="emptyMessage" style="display:none;">No projects found matching your selected filters.</p>

        <div id="projectsList" class="projects-container">
            @foreach (var project in Model.AlignedProjects)
            {
                <div class="project-card" data-title="@project.Title" data-area="@project.ResearchArea">
                    <div class="card-header-icon">
                        <i class="fas fa-file-alt"></i>
                    </div>
                    <h5>@project.Title</h5>
                    <p class="mb-1"><b>Research Area:</b> @project.ResearchArea</p>
                    <p class="mb-1"><b>Tech Stack:</b></p>
                    <div class="mb-2">
                        @foreach (var tech in project.TechStack)
                        {
                            <span class="tech-tag">@tech</span>
                        }
                    </div>
                    <a class="view-more" onclick="openCustomModal('@project.ProjectId', '@Uri.EscapeDataString(project.Title)', '@Uri.EscapeDataString(project.ResearchArea)', '@Uri.EscapeDataString(string.Join(",", project.TechStack))', '@Uri.EscapeDataString(project.AbstractText ?? "")')">
                        View More Details
                    </a>
                </div>
            }
        </div>
    </div>
</div>

<div id="reviewBoardModalOverlay" class="custom-modal-overlay" onclick="closeCustomModalOutside(event)">
    <div class="custom-modal-content">
        <input type="hidden" id="selectedProjectId" />

        <div class="modal-header-custom">
            <h4 id="modalTitle">Project Title</h4>
            <button class="btn-close-custom" onclick="closeCustomModal()">&times;</button>
        </div>

        <div class="modal-body-custom">
            <p><b>Research Area:</b> <span id="modalArea"></span></p>
            <p><b>Tech Stack:</b></p>
            <div id="modalTechStack" class="tech-stack-container-modal"></div>
            <p><b>Abstract:</b></p>
            <div class="modal-abstract">
                <span id="modalAbstract"></span>
            </div>
        </div>

        <div class="modal-footer-custom">
            <button type="button" class="btn-accept" onclick="acceptProject()">Accept Project</button>
            <button type="button" class="btn-cancel" onclick="closeCustomModal()">Cancel</button>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/Supervisor/ReviewBoard.js" asp-append-version="true"></script>
}