@{
    ViewData["Title"] = "Manage Users";
}

@section Styles {
    <link rel="stylesheet" href="~/css/Admin/UsersStyle.css" asp-append-version="true" />
}

<div class="dashboard-wrapper mt-2">
    <h2 class="text-white mb-4" style="font-family: var(--font-heading);">
        Welcome, <span class="text-capitalize">@ViewBag.FirstName</span>
    </h2>

    <div class="mb-4">
        <button class="btn-add-user d-flex align-items-center gap-2" data-bs-toggle="modal" data-bs-target="#addUserModal">
            <i class="fas fa-plus"></i> Add User
        </button>
    </div>

    <div class="directory-card">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3 class="text-white fw-bold m-0" style="font-family: var(--font-heading);">User Directory</h3>

            <select id="userRoleFilter" class="form-select directory-filter shadow-none">
                <option value="students" selected>Students</option>
                <option value="supervisors">Supervisors</option>
                <option value="admins">Admin</option>
            </select>
        </div>

		@model Blindsync_PAS_System.ViewModels.ManageUsersVM
        <div class="table-responsive">

            <table id="table-students" class="directory-table">
                <thead>
                    <tr>
                        <th class="text-start px-4">Student ID</th>
                        <th>Student Name</th>
                        <th>Email Address</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var student in Model.Students)
                    {
						var badgeClass = student.IsActive ? "badge-active" : "badge-inactive";
						var statusText = student.IsActive ? "Active" : "Inactive";

						<tr class="directory-row">
							<td>@student.StudentId</td>
							<td>@student.Name</td>
							<td>@student.Email</td>
							<td><span class="status-badge @badgeClass">@statusText</span></td>
                            <td>
                                <button class="action-btn icon-edit"
                                        data-userid="@student.UserId"
                                        data-firstname="@student.FirstName"
                                        data-lastname="@student.LastName"
                                        data-email="@student.Email"
                                        data-role="Student"
                                        data-studentid="@student.StudentId">
                                    <i class="fas fa-file-alt"></i>
                                </button>
                                <button class="action-btn icon-toggle" data-userid="@student.UserId" data-name="@student.Name" data-isactive="@student.IsActive.ToString().ToLower()">
                                    @if (student.IsActive)
                                    {
                                        <i class="fas fa-times text-danger" title="Deactivate User"></i>
                                    }
                                    else
                                    {
                                        <i class="fas fa-undo text-success" title="Reactivate User"></i>
                                    }
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <table id="table-supervisors" class="directory-table d-none">
                <thead>
                    <tr>
                        <th class="text-start px-4">Supervisor ID</th>
                        <th>Supervisor Name</th>
                        <th>Email Address</th>
                        <th>Project Quota</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var sup in Model.Supervisors)
                    {
                        var badgeClass = sup.IsActive ? "badge-active" : "badge-inactive";
                        var statusText = sup.IsActive ? "Active" : "Inactive";

                        <tr class="directory-row">
                            <td>@sup.SupervisorId</td>
                            <td>@sup.Name</td>
                            <td>@sup.Email</td>
                            <td>@sup.ProjectQuota</td>
                            <td><span class="status-badge @badgeClass">@statusText</span></td>
                            <td>
                                <button class="action-btn icon-edit"
                                        data-userid="@sup.UserId"
                                        data-firstname="@sup.FirstName"
                                        data-lastname="@sup.LastName"
                                        data-email="@sup.Email"
                                        data-role="Supervisor"
                                        data-supervisorid="@sup.SupervisorId"
                                        data-quota="@sup.ProjectQuota">
                                    <i class="fas fa-file-alt"></i>
                                </button>
                                <button class="action-btn icon-toggle" data-userid="@sup.UserId" data-name="@sup.Name" data-isactive="@sup.IsActive.ToString().ToLower()">
                                    @if (sup.IsActive)
                                    {
                                        <i class="fas fa-times text-danger" title="Deactivate User"></i>
                                    }
                                    else
                                    {
                                        <i class="fas fa-undo text-success" title="Reactivate User"></i>
                                    }
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <table id="table-admins" class="directory-table d-none">
                <thead>
                    <tr>
                        <th class="text-start px-4">Admin ID</th>
                        <th>Admin Name</th>
                        <th>Email Address</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var admin in Model.Admins)
                    {
                        var badgeClass = admin.IsActive ? "badge-active" : "badge-inactive";
                        var statusText = admin.IsActive ? "Active" : "Inactive";

                        <tr class="directory-row">
                            <td>@admin.AdminId</td>
                            <td>@admin.Name</td>
                            <td>@admin.Email</td>
                            <td><span class="status-badge @badgeClass">@statusText</span></td>
                            <td>
                                <button class="action-btn icon-edit"
                                        data-userid="@admin.UserId"
                                        data-firstname="@admin.FirstName"
                                        data-lastname="@admin.LastName"
                                        data-email="@admin.Email"
                                        data-role="Admin">
                                    <i class="fas fa-file-alt"></i>
                                </button>
                                <button class="action-btn icon-toggle" data-userid="@admin.UserId" data-name="@admin.Name" data-isactive="@admin.IsActive.ToString().ToLower()">
                                    @if (admin.IsActive)
                                    {
                                        <i class="fas fa-times text-danger" title="Deactivate User"></i>
                                    }
                                    else
                                    {
                                        <i class="fas fa-undo text-success" title="Reactivate User"></i>
                                    }
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>
    </div>
</div>

<div class="modal fade" id="addUserModal" tabindex="-1" aria-labelledby="addUserModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width: 500px;">
        <div class="modal-content custom-modal-content">

            <div class="custom-modal-header">
                <h2 class="fw-bold text-dark m-0" style="font-family: var(--font-heading); font-size: 1.8rem;">Add User</h2>
                <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="custom-modal-body">
                <input type="hidden" id="editUserId" value="">
                <form id="addUserForm">
                    <div class="row g-3">
                        <div class="col-6">
                            <label class="custom-label">First Name</label>
                            <input type="text" id="addFirstName" class="form-control custom-input-pill shadow-none" required>
                        </div>
                        <div class="col-6">
                            <label class="custom-label">Last Name</label>
                            <input type="text" id="addLastName" class="form-control custom-input-pill shadow-none" required>
                        </div>

                        <div class="col-6">
                            <label class="custom-label">Email</label>
                            <input type="email" id="addEmail" class="form-control custom-input-pill shadow-none" required>
                        </div>
                        <div class="col-6">
                            <label class="custom-label">Role</label>
                            <select class="form-select custom-select-pill shadow-none" id="modalRoleSelect">
                                <option value="Admin" selected>Admin</option>
                                <option value="Student">Student</option>
                                <option value="Supervisor">Supervisor</option>
                            </select>
                        </div>

                        <div class="col-12">
                            <label class="custom-label">Password</label>
                            <div class="position-relative">
                                <input type="password" id="modalPasswordInput" class="form-control custom-input-pill shadow-none w-100" style="padding-right: 45px;" required>
                                <i id="togglePasswordIcon" class="far fa-eye text-muted position-absolute" style="right: 18px; top: 50%; transform: translateY(-50%); cursor: pointer;"></i>
                            </div>
                        </div>

                        <div class="col-12 dynamic-field d-none" id="field-student">
                            <label class="custom-label">Student ID</label>
                            <input type="text" id="addStudentId" class="form-control custom-input-pill shadow-none">
                        </div>

                        <div class="col-6 dynamic-field d-none" id="field-supervisor-id">
                            <label class="custom-label">Supervisor ID</label>
                            <input type="text" id="addSupervisorId" class="form-control custom-input-pill shadow-none">
                        </div>
                        <div class="col-6 dynamic-field d-none" id="field-supervisor-quota">
                            <label class="custom-label">Project Quota</label>
                            <input type="number" id="addQuota" class="form-control custom-input-pill shadow-none">
                        </div>
                    </div>

                    <div class="row g-4 mt-3">
                        <div class="col-6">
                            <button type="submit" class="btn btn-add-pill w-100 d-flex justify-content-center align-items-center">Add</button>
                        </div>
                        <div class="col-6">
                            <button type="button" class="btn btn-cancel-pill w-100 d-flex justify-content-center align-items-center" data-bs-dismiss="modal">Cancel</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/Admin/Users.js" asp-append-version="true"></script>
}