@model Blindsync_PAS_System.ViewModels.UserProfileVM

<div class="modal-backdrop" id="profileModalBackdrop" style="display:flex;">
    <div class="profile-modal-container">
        <div class="profile-header">
            <h2>My Profile</h2>
            <button type="button" class="close-btn" onclick="closeProfileModal()"><i class="fas fa-times"></i></button>
        </div>

        <div class="profile-tabs">
            <button type="button" class="tab-btn active" onclick="switchTab('basic', this)">Basic Details</button>
            <button type="button" class="tab-btn" onclick="switchTab('security', this)">Security</button>
        </div>

        <form id="profileAjaxForm" onsubmit="submitProfileForm(event)" class="profile-form">
            @Html.AntiForgeryToken()

            <div id="tab-basic" class="tab-content active">
                <div class="form-group">
                    <label asp-for="FirstName">FIRST NAME</label>
                    <input asp-for="FirstName" class="form-input" required />
                </div>
                <div class="form-group">
                    <label asp-for="LastName">LAST NAME</label>
                    <input asp-for="LastName" class="form-input" required />
                </div>
                <div class="form-group">
                    <label asp-for="Email">EMAIL ADDRESS</label>
                    <input asp-for="Email" class="form-input" type="email" required />
                </div>
            </div>

            <div id="tab-security" class="tab-content">
                <div class="form-group">
                    <label asp-for="CurrentPassword">CURRENT PASSWORD</label>
                    <div class="password-wrapper">
                        <input asp-for="CurrentPassword" class="form-input" type="password" id="currentPw" />
                        <i class="fas fa-eye toggle-password" onclick="toggleVisibility('currentPw', this)"></i>
                    </div>
                </div>
                <div class="form-group">
                    <label asp-for="NewPassword">NEW PASSWORD</label>
                    <div class="password-wrapper">
                        <input asp-for="NewPassword" class="form-input" type="password" id="newPw" />
                        <i class="fas fa-eye toggle-password" onclick="toggleVisibility('newPw', this)"></i>
                    </div>
                </div>
                <div class="form-group">
                    <label asp-for="ConfirmNewPassword">CONFIRM NEW PASSWORD</label>
                    <div class="password-wrapper">
                        <input asp-for="ConfirmNewPassword" class="form-input" type="password" id="confirmPw" />
                        <i class="fas fa-eye toggle-password" onclick="toggleVisibility('confirmPw', this)"></i>
                    </div>
                </div>
            </div>

            <div class="profile-actions">
                <button type="submit" class="btn-save">Save Changes</button>
                <button type="button" class="btn-cancel" onclick="closeProfileModal()">Cancel</button>
            </div>
        </form>
    </div>
</div>