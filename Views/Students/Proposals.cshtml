@using System.Text.Encodings.Web
@model IEnumerable<Blindsync_PAS_System.Models.Project>

<div class="proposals-list">
    @if (Model != null && Model.Any())
    {
        @foreach (var project in Model)
        {
            <div class="proposal-row" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px;">

                <div class="proposal-left-group" style="display: flex; align-items: center; gap: 20px;">

                    <div class="proposal-icon-wrapper">
                        <i class="fas fa-clipboard-list" style="font-size: 3.5rem; color: #17cfc3;"></i>
                    </div>

                    <div class="proposal-details">
                        <h3 style="margin: 0 0 8px 0;">@project.Title</h3>
                        <p style="margin: 0 0 4px 0;">
                            Research Area: <span class="sub-text">@(project.Area?.Name ?? "General")</span>
                        </p>
                        <p style="margin: 0;">
                            Date of Submission: <span class="sub-text">@project.CreatedAt.ToString("dd MMM yyyy")</span>
                        </p>
                    </div>
                </div>

                <div class="proposal-status-section" style="display: flex; flex-direction: column; align-items: flex-end; gap: 12px; min-width: 150px;">
                    <span class="status-badge @project.Status.ToString().ToLower()">
                        @project.Status.ToString()
                    </span>

                    <a href="javascript:void(0)" class="view-abstract" style="text-decoration: underline; font-size: 0.9rem;"
                       onclick="openViewModal(
                                   '@Html.Raw(JavaScriptEncoder.Default.Encode(project.Title))',
                                   '@(project.Area?.Name ?? "N/A")',
                                   '@Html.Raw(JavaScriptEncoder.Default.Encode(project.TechStack ?? ""))',
                                   '@Html.Raw(JavaScriptEncoder.Default.Encode(project.Abstract ?? ""))')">
                        View Original Abstract
                    </a>
                </div>
            </div>
        }
    }
    else
    {
        <div class="no-data">
            <p>You haven't submitted any proposals yet.</p>
        </div>
    }
</div>

<div id="viewAbstractModal" class="modal-overlay" onclick="closeViewModalOutside(event)">
    <div class="modal-container">
        <div class="modal-header">
            <h2 id="modalTitle">[Project Title]</h2>
            <span class="close-btn" onclick="closeViewModal()">&times;</span>
        </div>

        <div class="modal-body">
            <div class="form-group" style="margin-bottom: 15px;">
                <label>Research Area</label>
                <div id="modalArea" class="soft-input" style="height: auto; background: #f0f0f0;"></div>
            </div>

            <div class="form-group">
                <label>Tech Stack</label>
                <div id="modalTechStack" class="tag-container">
                </div>
            </div>

            <div class="form-group">
                <label>Abstract</label>
                <div id="modalAbstractText" class="soft-input" style="min-height: 160px; background: #E0E0E0; overflow-y: auto;"></div>
            </div>
        </div>
    </div>
</div>