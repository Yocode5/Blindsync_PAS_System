@model Blindsync_PAS_System.ViewModels.AdminOverviewVM

@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = null; 
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BlindSync</title>
    <style>
        /* Pure CSS Implementation matching the UI */
        :root {
            --bg-gradient: linear-gradient(135deg, #2b5876 0%, #4e4376 100%);
            --card-bg: rgba(255, 255, 255, 0.1);
            --nav-bg: #e2e8f0;
            --text-light: #ffffff;
            --text-dark: #1e293b;
            --status-matched: #10b981;
            --status-pending: #f59e0b;
            --status-review: #ef4444;
        }
        body {
            margin: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: var(--bg-gradient);
            color: var(--text-light);
            min-height: 100vh;
            padding: 2rem;
        }
        .admin-container {
            max-width: 1200px;
            margin: 0 auto;
        }
        /* Top Navigation Bar */
        .top-nav {
            background: var(--nav-bg);
            border-radius: 50px;
            padding: 1rem 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            color: var(--text-dark);
            margin-bottom: 2rem;
        }
        .nav-logo { font-size: 1.5rem; font-weight: bold; color: var(--text-dark); }
        
        .nav-links {
            display: flex;
            gap: 2rem;
        }        
        .nav-links a {
            text-decoration: none;
            color: var(--text-dark);
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }
        .nav-actions button {
            padding: 0.5rem 1.5rem;
            border: none;
            border-radius: 20px;
            font-weight: bold;
            cursor: pointer;
            margin-left: 1rem;
        }
        .btn-profile { background: #475569; color: white; }
        .btn-logout { background: #ef4444; color: white; }

        /* Welcome & Stats Section */
        .welcome-text {
            font-size: 1.8rem;
            margin-bottom: 1.5rem;
            text-decoration: underline;
            text-decoration-color: #3b82f6;
        }
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 1.5rem;
            margin-bottom: 2rem;
        }
        .stat-card {
            background: var(--card-bg);
            backdrop-filter: blur(10px);
            padding: 1.5rem;
            border-radius: 15px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        }
        .stat-title { font-size: 1rem; color: #cbd5e1; display: flex; align-items: center; gap: 0.5rem; }
        .stat-value { font-size: 2.5rem; font-weight: bold; margin-top: 0.5rem; }

        /* Table Section */
        .table-container {
            background: rgba(15, 23, 42, 0.6);
            border-radius: 15px;
            padding: 1.5rem;
        }
        .table-container h2 { margin-top: 0; margin-bottom: 1rem; }

        .data-table {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0 0.5rem;
        }
        .data-table th {
            text-align: left;
            padding: 1rem;
            color: #94a3b8;
            font-weight: 600;
        }
        .data-table td {
            background: rgba(255, 255, 255, 0.05);
            padding: 1rem;
        }
        .data-table tr td:first-child { border-top-left-radius: 8px; border-bottom-left-radius: 8px; }
        .data-table tr td:last-child { border-top-right-radius: 8px; border-bottom-right-radius: 8px; }

        .status-badge {
            padding: 0.25rem 0.75rem;
            border-radius: 12px;
            font-size: 0.85rem;
            font-weight: bold;
        }
        .status-Matched { background: var(--status-matched); color: white; }
        .status-Pending { background: var(--status-pending); color: white; }
        .status-Under-Review { background: var(--status-review); color: white; }

        .action-icons { display: flex; gap: 0.5rem; cursor: pointer; color: #94a3b8; }
    </style>
</head>
<body>
    <div class="admin-container">
        <div class="top-nav">
            <div class="nav-logo">BlindSync</div>
            <div class="nav-links">
                <a href="#">Overview</a>
                <a href="#">Users</a>
                <a href="#">Research Areas</a>
            </div>
            <div class="nav-actions">
                <button class="btn-profile">Profile</button>
                <button class="btn-logout">Logout</button>
            </div>
        </div>
        <h1 class="welcome-text">Welcome, Admin!</h1>
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-title">👥 Students</div>
                <div class="stat-value">@Model.TotalStudents</div>
            </div>
            <div class="stat-card">
                <div class="stat-title">🔄 Total Matched</div>
                <div class="stat-value">@Model.TotalMatched</div>
            </div>
            <div class="stat-card">
                <div class="stat-title">👨‍🏫 Supervisors</div>
                <div class="stat-value">@Model.TotalSupervisors</div>
            </div>
            <div class="stat-card">
                <div class="stat-title">⏳ Pending</div>
                <div class="stat-value">@Model.TotalPending</div>
            </div>
        </div>
        <div class="table-container">
            <h2>System Overview</h2>
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Project Title</th>
                        <th>Student ID</th>
                        <th>Student Name</th>
                        <th>Supervisor Name</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if(Model.Projects != null && Model.Projects.Any())
                    {
                        foreach(var project in Model.Projects)
                        {
                            <tr>
                                <td>@project.ProjectTitle</td>
                                <td>@project.StudentId</td>
                                <td>@project.StudentName</td>
                                <td>@project.SupervisorName</td>
                                <td>
                                    <span class="status-badge status-@project.Status.Replace(" ", "-")">
                                        @project.Status
                                    </span>
                                </td>
                                <td>
                                    <div class="action-icons">
                                        <span>✏️</span> 
                                        <span>❌</span>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</body>
</html>