@model Blindsync_PAS_System.Models.Student

@{
    ViewData["Title"] = "Student Dashboard";
}

@* @await Html.PartialAsync("_StudentNavbar") *@

<div class="dashboard-page">
    <div class="dashboard-content">
        <h1 class="welcome-text">Welcome, [FirstName]</h1>

        <div class="status-card">
            <h2 class="card-title">Matching Status</h2>

            <div class="add-project-zone" onclick="openAddProjectModal()">
                <div class="icon-circle">
                    <i class="fas fa-plus"></i>
                </div>
                <p>Click To Add Project</p>
            </div>
        </div>
    </div>
</div>