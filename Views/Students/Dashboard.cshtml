@model Blindsync_PAS_System.Models.User

@{
    ViewData["Title"] = "Student Dashboard";
}

@if (TempData["SuccessMessage"] != null)
{
    <div id="toastNotification" class="custom-toast">
        <i class="fas fa-check-circle"></i>
        <span>@TempData["SuccessMessage"]</span>
    </div>
}

<div class="dashboard-page">
    <div class="dashboard-content">
        <h1 class="welcome-text">Welcome, @Model.FirstName</h1>

        <div class="status-card">
            <h2 class="card-title">Matching Status</h2>

            <div class="add-project-zone" onclick="openModal()">
                <div class="icon-circle">
                    <i class="fas fa-plus"></i>
                </div>
                <p>Click To Add Project</p>
            </div>
        </div>
    </div>
</div>

<div id="proposalModal" class="modal-overlay">
    <div class="modal-container">
        <div class="modal-header">
            <h2>Create Proposal</h2>
            <span class="close-btn" onclick="closeModal()">&times;</span>
        </div>

        <form asp-controller="Students" asp-action="CreateProposal" method="post" class="modal-form">
            <div class="form-row">
                <div class="form-group">
                    <label>Project Title</label>
                    <input type="text" name="Title" placeholder="Enter title..." class="soft-input" required>
                </div>
                <div class="form-group">
                    <label>Research Area</label>

                    <div class="custom-dropdown-container" id="researchDropdown">

                        <div class="custom-dropdown-trigger" onclick="toggleDropdown(event)">
                            <span id="selectedResearchText">Select Research Area</span>
                            <i class="fas fa-chevron-down dropdown-icon"></i>
                        </div>

                        <input type="hidden" name="ResearchAreaId" id="hiddenResearchAreaId" required>

                        <ul class="custom-dropdown-options" id="dropdownOptions">
                            @if (ViewBag.ResearchAreas != null)
                            {
                                foreach (var area in ViewBag.ResearchAreas)
                                {
                                    <li onclick="selectResearchArea('@area.Id', '@area.Name')">@area.Name</li>
                                }
                            }
                        </ul>

                    </div>
                </div>
            </div>

            <div class="form-group">
                <label>Tech Stack</label>

                <input type="text" id="techInput" placeholder="e.g. React, Node.js (Press Enter)" class="soft-input">

                <input type="hidden" name="TechStack" id="hiddenTechStack">

                <div class="tag-container" id="techTagContainer">
                </div>
            </div>

            <div class="form-group">
                <label>Abstract</label>
                <textarea name="Abstract" rows="5" class="soft-input" placeholder="Enter abstract..." required></textarea>
            </div>

            <div class="modal-actions">
                <button type="submit" class="btn-add">Add</button>
                <button type="button" class="btn-cancel" onclick="closeModal()">Cancel</button>
            </div>
        </form>
    </div>
</div>
